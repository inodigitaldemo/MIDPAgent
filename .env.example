# SharePoint configuration
# Full URL to your SharePoint site, e.g. https://contoso.sharepoint.com/sites/mysite
SHAREPOINT_SITE_URL=https://your-tenant.sharepoint.com/sites/your-site

# Title of the SharePoint list that holds the Master Information Delivery Plan
SHAREPOINT_LIST_NAME=Master Information Delivery Plan

# SharePoint authentication – choose ONE of the two options below.

# Option A: Username / Password (delegated access)
SHAREPOINT_USERNAME=user@your-tenant.onmicrosoft.com
SHAREPOINT_PASSWORD=your-password

# Option B: App-only (client credentials)  ← comment out Option A and uncomment these
# SHAREPOINT_CLIENT_ID=your-azure-app-client-id
# SHAREPOINT_CLIENT_SECRET=your-azure-app-client-secret

# Azure AI Projects configuration
# Connection string shown on the Overview page of your Azure AI Foundry project
# Format: <HostName>;<AzureSubscriptionId>;<ResourceGroup>;<ProjectName>
AZURE_AI_PROJECT_ENDPOINT=https://your-project.services.ai.azure.com/api/projects/your-project
